# wraquant environment variables
# Copy this file to .env and fill in your API keys

# ========================
# Financial Modeling Prep (FMP)
# ========================
# Required for: fundamental analysis, company profiles, financial statements,
# earnings data, news, SEC filings, stock screening
# Get your key at: https://financialmodelingprep.com/developer/docs
FMP_API_KEY=your_fmp_api_key_here

# ========================
# Alpha Vantage (optional)
# ========================
# Alternative data provider for historical prices and fundamentals
ALPHAVANTAGE_API_KEY=your_alphavantage_key_here

# ========================
# FRED (optional)
# ========================
# Federal Reserve Economic Data — macro indicators, Treasury rates
# Get your key at: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_key_here

# ========================
# Nasdaq Data Link (optional)
# ========================
# Alternative macro/financial data
NASDAQ_API_KEY=your_nasdaq_key_here
